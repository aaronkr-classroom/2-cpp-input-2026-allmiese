#include <ioastream>

using std::cin;
using std::cout;
using std::endl;

int main(void) {
    cout << "1. Square OR 2. Rect? >>> ";

    int option;
    cin >> option;

    if (option != 1 && option !=2) {
            cout << "Error: Only choose 1 or 2!";
            return 0x712F;
        }

    cout << "What size square? >>> ";

    int size;
    cin >> size; // 10

    for (int i = 0; i < size; i++) {
        for (int j = 0; j < size; j++) {
            if (option == 1) {
                cout << "*"; // 10x10
            }
            else if (option == 2) {
                cout << "**"; // 20x10
            }
        }
        else {
            cout << "Error: Only choose 1 or 2!";
            return 0x712F;
        }

        cout << endl;
    }

    return 0;
}